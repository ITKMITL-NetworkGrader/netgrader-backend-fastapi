# Template: route_check.j2
# Description: Check routing table configuration on network devices and Linux systems
# Parameters:
#   - route_command: Command to show routes (default: show ip route for network, ip route show for Linux)
#   - destination_network: Specific network/route to check for (optional)
#   - next_hop: Specific next hop IP to verify (optional)
#   - default_route_required: Whether default route must be present (default: false)
# Custom Fields:
#   - has_default_route: Whether default route exists
#   - route_count: Total number of routes found
#   - specific_routes: List of specific routes found
#   - destination_found: Whether specified destination network was found
#   - next_hop_present: Whether specified next hop was found

- name: "Get routing table from network device"
  ansible.netcommon.net_get:
    command: "{{ route_command | default('show ip route') }}"
  register: route_result_net
  when: ansible_network_os is defined
  ignore_errors: true

- name: "Get routing table from Linux system"
  shell: |
    {% if route_command is defined %}
    {{ route_command }}
    {% else %}
    ip route show
    {% endif %}
  register: route_result_linux
  when: ansible_network_os is not defined
  ignore_errors: true

- name: "Store route check results using CLAUDE.md approach"
  set_fact:
    result_{{ task_id }}:
      status: >-
        {%- set route_output = route_result_net.stdout | default('') if ansible_network_os is defined else route_result_linux.stdout | default('') -%}
        {%- if destination_network is defined -%}
          {{ 'passed' if destination_network in route_output else 'failed' }}
        {%- elif next_hop is defined -%}
          {{ 'passed' if next_hop in route_output else 'failed' }}
        {%- elif default_route_required is defined and default_route_required -%}
          {{ 'passed' if ('0.0.0.0/0' in route_output or 'default' in route_output) else 'failed' }}
        {%- else -%}
          {%- if ansible_network_os is defined -%}
            {{ 'passed' if not route_result_net.failed else 'failed' }}
          {%- else -%}
            {{ 'passed' if route_result_linux.rc == 0 else 'failed' }}
          {%- endif -%}
        {%- endif -%}
      stdout: >-
        {%- if ansible_network_os is defined -%}
          {{ route_result_net.stdout | default('') }}
        {%- else -%}
          {{ route_result_linux.stdout | default('') }}
        {%- endif -%}
      stderr: >-
        {%- if ansible_network_os is defined -%}
          {{ route_result_net.stderr | default('') }}
        {%- else -%}
          {{ route_result_linux.stderr | default('') }}
        {%- endif -%}
      rc: >-
        {%- if ansible_network_os is defined -%}
          {{ 0 if not route_result_net.failed else 1 }}
        {%- else -%}
          {{ route_result_linux.rc | default(1) }}
        {%- endif -%}
      raw: >-
        {%- if ansible_network_os is defined -%}
          {{ route_result_net }}
        {%- else -%}
          {{ route_result_linux }}
        {%- endif -%}
      custom:
        device_type: >-
          {%- if ansible_network_os is defined -%}
            network_device
          {%- else -%}
            linux_system
          {%- endif -%}
        route_command: >-
          {%- if route_command is defined -%}
            {{ route_command }}
          {%- elif ansible_network_os is defined -%}
            show ip route
          {%- else -%}
            ip route show
          {%- endif -%}
        destination_network: "{{ destination_network | default('not_specified') }}"
        next_hop: "{{ next_hop | default('not_specified') }}"
        default_route_required: "{{ default_route_required | default(false) }}"
        has_default_route: >-
          {%- set route_output = route_result_net.stdout | default('') if ansible_network_os is defined else route_result_linux.stdout | default('') -%}
          {{ '0.0.0.0/0' in route_output or 'default' in route_output }}
        route_count: >-
          {%- set route_output = route_result_net.stdout | default('') if ansible_network_os is defined else route_result_linux.stdout | default('') -%}
          {{ route_output.split('\n') | length if route_output else 0 }}
        specific_routes: >-
          {%- set route_output = route_result_net.stdout | default('') if ansible_network_os is defined else route_result_linux.stdout | default('') -%}
          {%- set routes = [] -%}
          {%- for line in route_output.split('\n') -%}
            {%- if '/' in line and ('via' in line or 'dev' in line) -%}
              {%- set _ = routes.append(line.strip()) -%}
            {%- endif -%}
          {%- endfor -%}
          {{ routes }}
        destination_found: >-
          {%- if destination_network is defined -%}
            {%- set route_output = route_result_net.stdout | default('') if ansible_network_os is defined else route_result_linux.stdout | default('') -%}
            {{ destination_network in route_output }}
          {%- else -%}
            null
          {%- endif -%}
        next_hop_present: >-
          {%- if next_hop is defined -%}
            {%- set route_output = route_result_net.stdout | default('') if ansible_network_os is defined else route_result_linux.stdout | default('') -%}
            {{ next_hop in route_output }}
          {%- else -%}
            null
          {%- endif -%}
        command_successful: >-
          {%- if ansible_network_os is defined -%}
            {{ not route_result_net.failed }}
          {%- else -%}
            {{ route_result_linux.rc == 0 }}
          {%- endif -%}
  tags:
    - test_id:{{ task_id }}
    - result_storage