# Template: network_ip_int.j2
# Description: Check IP address on network device interface (with native Ansible proxy support)
# Parameters:
#   - interface_name: Name of the interface to check (required)
#   - expected_ip: Expected IP address (optional)

- name: "Get interface facts from {{ execution_device }}"
  delegate_to: "{{ execution_device }}"
  block:
    - name: "Attempt modern SSH connection"
      cisco.ios.ios_facts:
        gather_subset:
          - interfaces
      register: interface_facts
  rescue:
    - name: "Set legacy SSH args"
      set_fact:
        ansible_ssh_common_args: '-o KexAlgorithms=+diffie-hellman-group-exchange-sha1 -o HostKeyAlgorithms=+ssh-rsa'
    - name: "Retry with legacy SSH"
      cisco.ios.ios_facts:
        gather_subset:
          - interfaces
      register: interface_facts

- name: "Extract interface IP"
  set_fact:
    actual_ip: "{{ interface_facts.ansible_facts.ansible_net_interfaces[interface_name].ipv4[0].address if interface_facts.ansible_facts is defined and interface_name in interface_facts.ansible_facts.ansible_net_interfaces and interface_facts.ansible_facts.ansible_net_interfaces[interface_name].ipv4 is defined and interface_facts.ansible_facts.ansible_net_interfaces[interface_name].ipv4 | length > 0 else 'not_found' }}"
  when: interface_facts is defined and interface_facts.ansible_facts is defined

- name: "Store interface results"
  set_fact:
    result_{{ task_id }}:
      status: "{{ 'passed' if actual_ip is defined and actual_ip != 'not_found' and (expected_ip is not defined or actual_ip == expected_ip) else 'failed' }}"
      stdout: "Interface {{ interface_name }} has IP {{ actual_ip | default('not_found') }}"
      stderr: "{{ 'Could not find IPv4 address on interface ' + interface_name if actual_ip is not defined or actual_ip == 'not_found' else '' }}"
      rc: "{{ 0 if actual_ip is defined and actual_ip != 'not_found' and (expected_ip is not defined or actual_ip == expected_ip) else 1 }}"
      raw: "{{ interface_facts | default({}) }}"
      custom:
        interface_name: "{{ interface_name }}"
        expected_ip: "{{ expected_ip | default('not_specified') }}"
        actual_ip: "{{ actual_ip | default('not_found') }}"
        match: "{{ actual_ip == expected_ip if actual_ip is defined and expected_ip is defined else null }}"
        proxy_execution: "{{ hostvars[execution_device].proxy_host is defined and hostvars[execution_device].proxy_host != '' }}"
        proxy_host: "{{ hostvars[execution_device].proxy_host | default('') }}"
  tags:
    - test_id:{{ task_id }}
    - result_storage