- name: Attempt connection and gather facts
  block:
    - name: "Attempt 1: Try connecting with modern SSH"
      cisco.ios.ios_facts:
        gather_subset:
          - interfaces
      register: interface_facts

  rescue:
    - name: "Attempt 2: Set legacy args and retry on SSH failure"
      set_fact:
        ansible_ssh_common_args: '-o KexAlgorithms=+diffie-hellman-group-exchange-sha1 -o HostKeyAlgorithms=+ssh-rsa'

    - name: "Retrying connection with legacy SSH..."
      cisco.ios.ios_facts:
        gather_subset:
          - interfaces
      register: interface_facts

- name: "Extract the actual IP from {{ interface_name }}"
  set_fact:
    actual_ip: "{{ interface_facts.ansible_facts.ansible_net_interfaces[interface_name].ipv4[0].address }}"
  when:
    - interface_name in interface_facts.ansible_facts.ansible_net_interfaces
    - interface_facts.ansible_facts.ansible_net_interfaces[interface_name].ipv4 is defined
    - interface_facts.ansible_facts.ansible_net_interfaces[interface_name].ipv4 | length > 0

- name: "Store interface check results using CLAUDE.md set_fact approach"
  set_fact:
    result_{{ task_id }}:
      status: >-
        {%- if actual_ip is defined -%}
          {{ 'passed' if actual_ip == expected_ip else 'failed' }}
        {%- else -%}
          failed
        {%- endif -%}
      stdout: >-
        {%- if actual_ip is defined -%}
          Interface {{ interface_name }} has IP {{ actual_ip }}
        {%- else -%}
          No IP address found on interface {{ interface_name }}
        {%- endif -%}
      stderr: >-
        {%- if actual_ip is not defined -%}
          Could not find IPv4 address on interface {{ interface_name }}
        {%- else -%}
          {{ '' }}
        {%- endif -%}
      rc: >-
        {%- if actual_ip is defined -%}
          {{ 0 if actual_ip == expected_ip else 1 }}
        {%- else -%}
          1
        {%- endif -%}
      raw: "{{ interface_facts }}"
      custom:
        interface_name: "{{ interface_name }}"
        expected_ip: "{{ expected_ip }}"
        actual_ip: "{{ actual_ip | default('not_found') }}"
        match: >-
          {%- if actual_ip is defined -%}
            {{ actual_ip == expected_ip }}
          {%- else -%}
            false
          {%- endif -%}
  tags:
    - test_id:{{ task_id }}
    - result_storage