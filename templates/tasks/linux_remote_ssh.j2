# Template: linux_remote_ssh.j2
# Description: Test SSH connectivity between Linux systems
# Parameters:
#   - target_ip: Target IP address or hostname (required)
#   - target_user: Username for SSH connection (default: root)
#   - timeout: SSH connection timeout in seconds (default: 10)
#   - ssh_key_path: Path to SSH private key (optional)
#   - test_command: Command to run after SSH connection (default: echo 'SSH connection successful')
# Custom Fields:
#   - target_ip: Target IP/hostname
#   - target_user: SSH username
#   - connection_successful: Whether SSH connection succeeded
#   - command_output: Output from test command
#   - connection_time: Time taken for connection

- name: "Test SSH connectivity to remote system"
  shell: |
    {% if ssh_key_path is defined %}
    ssh -i {{ ssh_key_path }} \
        -o ConnectTimeout={{ timeout | default(10) }} \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        {{ target_user | default('root') }}@{{ target_ip }} \
        "{{ test_command | default('echo SSH connection successful') }}"
    {% else %}
    ssh -o ConnectTimeout={{ timeout | default(10) }} \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        {{ target_user | default('root') }}@{{ target_ip }} \
        "{{ test_command | default('echo SSH connection successful') }}"
    {% endif %}
  register: ssh_result
  ignore_errors: true

- name: "Store SSH connectivity results using CLAUDE.md approach"
  set_fact:
    result_{{ task_id }}:
      status: >-
        {%- if ssh_result.rc == 0 and 'SSH connection successful' in ssh_result.stdout -%}
          passed
        {%- else -%}
          failed
        {%- endif -%}
      stdout: "{{ ssh_result.stdout | default('') }}"
      stderr: "{{ ssh_result.stderr | default('') }}"
      rc: "{{ ssh_result.rc | default(1) }}"
      raw: "{{ ssh_result }}"
      custom:
        target_ip: "{{ target_ip }}"
        target_user: "{{ target_user | default('root') }}"
        timeout: "{{ timeout | default(10) }}"
        connection_successful: "{{ ssh_result.rc == 0 }}"
        command_output: "{{ ssh_result.stdout | default('') }}"
        authentication_method: >-
          {%- if ssh_key_path is defined -%}
            key-based
          {%- else -%}
            password-based
          {%- endif -%}
        ssh_key_used: "{{ ssh_key_path | default('none') }}"
        error_type: >-
          {%- if ssh_result.rc != 0 and ssh_result.stderr is defined -%}
            {%- if 'Connection refused' in ssh_result.stderr -%}
              connection_refused
            {%- elif 'Connection timed out' in ssh_result.stderr -%}
              timeout
            {%- elif 'Permission denied' in ssh_result.stderr -%}
              authentication_failed
            {%- elif 'Host key verification failed' in ssh_result.stderr -%}
              host_key_failed
            {%- else -%}
              unknown
            {%- endif -%}
          {%- else -%}
            none
          {%- endif -%}
  tags:
    - test_id:{{ task_id }}
    - result_storage