{% raw %}
- name: "Test {{ test_id }} - SSH connectivity from {{ source_device }} to {{ target_device }}"
  shell: |
    ssh -o ConnectTimeout={{ timeout | default(10) }} \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        {{ target_user | default('root') }}@{{ target_ip | default(target_device) }} \
        "echo 'SSH connection successful'"
  register: ssh_result
  delegate_to: "{{ source_device }}"
  ignore_errors: true
  tags:
    - test_id:{{ test_id }}
    - points:{{ points }}

- name: "Evaluate SSH connectivity test {{ test_id }}"
  debug:
    msg: |
{% endraw %}
      {% if expected_result == "success" %}
      SSH test passed: {% raw %}{{ source_device }}{% endraw %} can SSH to {% raw %}{{ target_device }}{% endraw %}
      {% else %}
      SSH test failed: {% raw %}{{ source_device }}{% endraw %} cannot SSH to {% raw %}{{ target_device }}{% endraw %}
      {% endif %}
{% raw %}
  failed_when: >
{% endraw %}
    {% if expected_result == "success" %}
    ssh_result.rc != 0 or 'SSH connection successful' not in ssh_result.stdout
    {% else %}
    ssh_result.rc == 0 and 'SSH connection successful' in ssh_result.stdout
    {% endif %}
{% raw %}
  tags:
    - test_id:{{ test_id }}
    - points:{{ points }}
{% endraw %}