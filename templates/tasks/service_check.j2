# Template: service_check.j2
# Description: Check system service status and port availability on Linux systems
# Parameters:
#   - service_name: Name of the service to check (required)
#   - port: Port number to check availability (optional)
#   - service_manager: Service management system - systemctl/service/ps (default: systemctl)
#   - expected_status: Expected service status - active/inactive (optional)
# Custom Fields:
#   - service_name: Checked service name
#   - service_active: Whether service is running
#   - service_status: Service status string
#   - port: Checked port number
#   - port_open: Whether port is accessible
#   - process_count: Number of service processes found

- name: "Check service status"
  shell: |
    {% if service_manager | default('systemctl') == 'systemctl' %}
    systemctl is-active {{ service_name }} && echo "ACTIVE" || echo "INACTIVE"
    {% elif service_manager == 'service' %}
    service {{ service_name }} status && echo "RUNNING" || echo "STOPPED"
    {% else %}
    ps aux | grep -v grep | grep {{ service_name }} && echo "RUNNING" || echo "STOPPED"
    {% endif %}
  register: service_status_result
  ignore_errors: true

- name: "Check port availability"
  shell: |
    {% if port is defined %}
    netstat -tuln | grep :{{ port }} && echo "OPEN" || echo "CLOSED"
    {% else %}
    echo "NO_PORT_SPECIFIED"
    {% endif %}
  register: port_status_result
  ignore_errors: true
  when: port is defined

- name: "Get detailed service information"
  shell: |
    {% if service_manager | default('systemctl') == 'systemctl' %}
    systemctl status {{ service_name }} --no-pager -l 2>/dev/null || echo "Service not found or systemctl unavailable"
    {% else %}
    ps aux | grep {{ service_name }} | grep -v grep || echo "No processes found"
    {% endif %}
  register: service_details_result
  ignore_errors: true

- name: "Store service check results using CLAUDE.md approach"
  set_fact:
    result_{{ task_id }}:
      status: >-
        {%- if expected_status is defined -%}
          {%- if expected_status == "active" -%}
            {{ 'passed' if ('active' in service_status_result.stdout.lower() or 'running' in service_status_result.stdout.lower()) else 'failed' }}
          {%- elif expected_status == "inactive" -%}
            {{ 'passed' if ('inactive' in service_status_result.stdout.lower() or 'stopped' in service_status_result.stdout.lower()) else 'failed' }}
          {%- else -%}
            {{ 'passed' if service_status_result.rc == 0 else 'failed' }}
          {%- endif -%}
        {%- else -%}
          {{ 'passed' if ('active' in service_status_result.stdout.lower() or 'running' in service_status_result.stdout.lower()) else 'failed' }}
        {%- endif -%}
      stdout: "{{ service_status_result.stdout | default('') }}"
      stderr: "{{ service_status_result.stderr | default('') }}"
      rc: "{{ service_status_result.rc | default(1) }}"
      raw: 
        service_check: "{{ service_status_result }}"
        port_check: "{{ port_status_result if port is defined else {} }}"
        service_details: "{{ service_details_result }}"
      custom:
        service_name: "{{ service_name }}"
        service_manager: "{{ service_manager | default('systemctl') }}"
        expected_status: "{{ expected_status | default('not_specified') }}"
        service_active: "{{ 'active' in service_status_result.stdout.lower() or 'running' in service_status_result.stdout.lower() }}"
        service_status: "{{ service_status_result.stdout.strip() | lower }}"
        port: "{{ port | default('not_specified') }}"
        port_open: >-
          {%- if port is defined -%}
            {{ 'open' in port_status_result.stdout.lower() }}
          {%- else -%}
            null
          {%- endif -%}
        port_status: >-
          {%- if port is defined -%}
            {{ port_status_result.stdout.strip() | lower }}
          {%- else -%}
            not_checked
          {%- endif -%}
        process_count: >-
          {%- if service_details_result.stdout is defined -%}
            {{ (service_details_result.stdout | regex_findall(service_name) | length) }}
          {%- else -%}
            0
          {%- endif -%}
        service_details: "{{ service_details_result.stdout | default('') }}"
        check_successful: "{{ service_status_result.rc == 0 }}"
  tags:
    - test_id:{{ task_id }}
    - result_storage