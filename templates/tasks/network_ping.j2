- name: "Ping test to {{ target_ip | default(target_device) }} via proxy"
  delegate_to: "{{ proxy_host }}"
  shell: |
    sshpass -p "{{ proxy_target_credentials.ansible_password }}" ssh {{ proxy_ssh_args }} {{ proxy_target_credentials.ansible_user }}@{{ ansible_host }} 'ping -c {{ ping_count | default(3) }} {{ target_ip | default(target_device) }}'
  register: ping_result_proxy
  when: proxy_host is defined and proxy_host_ip is defined
  ignore_errors: yes

- name: "Ping test to {{ target_ip | default(target_device) }} from network device"
  delegate_to: "{{ execution_device }}"
  ansible.netcommon.net_ping:
    dest: "{{ target_ip | default(target_device) }}"
    count: "{{ ping_count | default(3) }}"
  register: ping_result_net
  when: proxy_host is not defined and hostvars[execution_device]['ansible_network_os'] is defined
  ignore_errors: true

- name: "Ping test to {{ target_ip | default(target_device) }} from Linux server"
  delegate_to: "{{ execution_device }}"
  ansible.builtin.shell: "ping -c {{ ping_count | default(3) }} {{ target_ip | default(target_device) }}"
  register: ping_result_linux
  when: proxy_host is not defined and (hostvars[execution_device]['ansible_network_os'] is not defined or hostvars[execution_device]['ansible_network_os'] is undefined)
  ignore_errors: true

- name: "Store proxy ping results"
  set_fact:
    result_{{ task_id }}:
      status: "{{ 'passed' if ping_result_proxy.rc == 0 else 'failed' }}"
      stdout: "{{ ping_result_proxy.stdout | default('') }}"
      stderr: "{{ ping_result_proxy.stderr | default('') }}"
      rc: "{{ ping_result_proxy.rc | default(1) }}"
      raw: "{{ ping_result_proxy }}"
      custom:
        target: "{{ target_ip | default(target_device) }}"
        packets_sent: "{{ ping_count | default(3) }}"
        packets_received: "{{ ping_result_proxy.stdout.split(' received')[0].split()[-1] if ' received' in ping_result_proxy.stdout else '0' }}"
        success_rate: "{{ ((ping_result_proxy.stdout.split(' received')[0].split()[-1] | int) / (ping_count | default(3)) * 100) | round(1) if ' received' in ping_result_proxy.stdout else 0 }}"
        avg_rtt: "{{ ping_result_proxy.stdout.split('rtt min/avg/max/mdev = ')[1].split('/')[1] if 'rtt min/avg/max/mdev = ' in ping_result_proxy.stdout else '0' }}"
        proxy_execution: true
        proxy_host: "{{ proxy_host }}"
  when: proxy_host is defined and proxy_host_ip is defined
  tags:
    - test_id:{{ task_id }}
    - result_storage

- name: "Store network device ping results"
  set_fact:
    result_{{ task_id }}:
      status: "{{ 'passed' if not ping_result_net.failed else 'failed' }}"
      stdout: "{{ ping_result_net.stdout | default('') }}"
      stderr: "{{ ping_result_net.stderr | default('') }}"
      rc: "{{ 0 if not ping_result_net.failed else 1 }}"
      raw: "{{ ping_result_net }}"
      custom:
        target: "{{ target_ip | default(target_device) }}"
        packets_sent: "{{ ping_count | default(3) }}"
        packets_received: "{{ ping_count | default(3) if not ping_result_net.failed else 0 }}"
        success_rate: "{{ 100 if not ping_result_net.failed else 0 }}"
        avg_rtt: "{{ ping_result_net.rtt.avg | default(0) if ping_result_net.rtt is defined else 0 }}"
        proxy_execution: false
  when: proxy_host is not defined and hostvars[execution_device]['ansible_network_os'] is defined
  tags:
    - test_id:{{ task_id }}
    - result_storage

- name: "Store Linux server ping results"
  set_fact:
    result_{{ task_id }}:
      status: "{{ 'passed' if ping_result_linux.rc == 0 else 'failed' }}"
      stdout: "{{ ping_result_linux.stdout | default('') }}"
      stderr: "{{ ping_result_linux.stderr | default('') }}"
      rc: "{{ ping_result_linux.rc | default(1) }}"
      raw: "{{ ping_result_linux }}"
      custom:
        target: "{{ target_ip | default(target_device) }}"
        packets_sent: "{{ ping_count | default(3) }}"
        packets_received: "{{ ping_result_linux.stdout.split(' received')[0].split()[-1] if ' received' in ping_result_linux.stdout else '0' }}"
        success_rate: "{{ ((ping_result_linux.stdout.split(' received')[0].split()[-1] | int) / (ping_count | default(3)) * 100) | round(1) if ' received' in ping_result_linux.stdout else 0 }}"
        avg_rtt: "{{ ping_result_linux.stdout.split('rtt min/avg/max/mdev = ')[1].split('/')[1] if 'rtt min/avg/max/mdev = ' in ping_result_linux.stdout else '0' }}"
        proxy_execution: false
  when: proxy_host is not defined and (hostvars[execution_device]['ansible_network_os'] is not defined or hostvars[execution_device]['ansible_network_os'] is undefined)
  tags:
    - test_id:{{ task_id }}
    - result_storage