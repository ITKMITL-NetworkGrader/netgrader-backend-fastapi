# Template: dhcp_check.j2
# Description: Check DHCP service status on network devices and Linux systems
# Parameters:
#   - dhcp_command: Command to check DHCP (network devices, default: show ip dhcp binding)
#   - dhcp_service_check: Service check method for Linux (default: systemctl)
#   - expected_result: Expected service state - enabled/disabled (optional)
#   - dhcp_pool: Specific DHCP pool name to verify (optional)
#   - service_name: DHCP service name to check (default: auto-detect)
# Custom Fields:
#   - dhcp_service_active: Whether DHCP service is running
#   - dhcp_pool: Target pool name
#   - pool_found: Whether specified pool was found
#   - binding_count: Number of DHCP bindings found
#   - service_method: Method used to check service

- name: "Check DHCP service on network device"
  ansible.netcommon.net_get:
    command: "{{ dhcp_command | default('show ip dhcp binding') }}"
  register: dhcp_result_net
  when: ansible_network_os is defined
  ignore_errors: true

- name: "Check DHCP service on Linux system"
  shell: |
    {% if dhcp_service_check | default('systemctl') == 'systemctl' %}
    {% if service_name is defined %}
    systemctl is-active {{ service_name }}
    {% else %}
    systemctl is-active dhcpd 2>/dev/null || systemctl is-active isc-dhcp-server 2>/dev/null || systemctl is-active dhcp 2>/dev/null
    {% endif %}
    {% else %}
    {% if service_name is defined %}
    ps aux | grep -v grep | grep {{ service_name }}
    {% else %}
    ps aux | grep -v grep | grep -E "(dhcpd|dhcp)"
    {% endif %}
    {% endif %}
  register: dhcp_result_linux
  when: ansible_network_os is not defined
  ignore_errors: true

- name: "Store DHCP check results using CLAUDE.md approach"
  set_fact:
    result_{{ task_id }}:
      status: >-
        {%- if ansible_network_os is defined -%}
          {%- if expected_result == "enabled" -%}
            {{ 'passed' if (dhcp_result_net.stdout is defined and not dhcp_result_net.failed) else 'failed' }}
          {%- elif expected_result == "disabled" -%}
            {{ 'passed' if dhcp_result_net.failed else 'failed' }}
          {%- elif dhcp_pool is defined -%}
            {{ 'passed' if (dhcp_result_net.stdout is defined and dhcp_pool in dhcp_result_net.stdout) else 'failed' }}
          {%- else -%}
            {{ 'passed' if not dhcp_result_net.failed else 'failed' }}
          {%- endif -%}
        {%- else -%}
          {%- if expected_result == "enabled" -%}
            {{ 'passed' if dhcp_result_linux.rc == 0 else 'failed' }}
          {%- elif expected_result == "disabled" -%}
            {{ 'passed' if dhcp_result_linux.rc != 0 else 'failed' }}
          {%- else -%}
            {{ 'passed' if dhcp_result_linux.rc == 0 else 'failed' }}
          {%- endif -%}
        {%- endif -%}
      stdout: >-
        {%- if ansible_network_os is defined -%}
          {{ dhcp_result_net.stdout | default('') }}
        {%- else -%}
          {{ dhcp_result_linux.stdout | default('') }}
        {%- endif -%}
      stderr: >-
        {%- if ansible_network_os is defined -%}
          {{ dhcp_result_net.stderr | default('') }}
        {%- else -%}
          {{ dhcp_result_linux.stderr | default('') }}
        {%- endif -%}
      rc: >-
        {%- if ansible_network_os is defined -%}
          {{ 0 if not dhcp_result_net.failed else 1 }}
        {%- else -%}
          {{ dhcp_result_linux.rc | default(1) }}
        {%- endif -%}
      raw: >-
        {%- if ansible_network_os is defined -%}
          {{ dhcp_result_net }}
        {%- else -%}
          {{ dhcp_result_linux }}
        {%- endif -%}
      custom:
        device_type: >-
          {%- if ansible_network_os is defined -%}
            network_device
          {%- else -%}
            linux_system
          {%- endif -%}
        dhcp_command: "{{ dhcp_command | default('show ip dhcp binding') }}"
        service_check_method: "{{ dhcp_service_check | default('systemctl') }}"
        expected_result: "{{ expected_result | default('not_specified') }}"
        dhcp_pool: "{{ dhcp_pool | default('not_specified') }}"
        dhcp_service_active: >-
          {%- if ansible_network_os is defined -%}
            {{ not dhcp_result_net.failed }}
          {%- else -%}
            {{ dhcp_result_linux.rc == 0 }}
          {%- endif -%}
        pool_found: >-
          {%- if dhcp_pool is defined -%}
            {%- if ansible_network_os is defined and dhcp_result_net.stdout is defined -%}
              {{ dhcp_pool in dhcp_result_net.stdout }}
            {%- elif ansible_network_os is not defined and dhcp_result_linux.stdout is defined -%}
              {{ dhcp_pool in dhcp_result_linux.stdout }}
            {%- else -%}
              false
            {%- endif -%}
          {%- else -%}
            null
          {%- endif -%}
        binding_count: >-
          {%- if ansible_network_os is defined and dhcp_result_net.stdout is defined -%}
            {{ dhcp_result_net.stdout.split('\n') | length - 1 }}
          {%- else -%}
            0
          {%- endif -%}
        service_name: "{{ service_name | default('auto-detect') }}"
  tags:
    - test_id:{{ task_id }}
    - result_storage