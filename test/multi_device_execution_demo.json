{
  "job_id": "multi_device_demo_001",
  "student_id": "demo_student",
  "lab_id": "demo_multi_device_lab",
  "part": {
    "part_id": "part1",
    "title": "Multi-Device Task Execution Demo - New Schema",
    "play": {
      "play_id": "play1",
      "ansible_tasks": [
        {
          "task_id": "task1",
          "template_name": "linux_ip_check",
          "execution_device": "server1",
          "parameters": {
            "interface_name": "eth0",
            "expected_ip": "192.168.1.10"
          },
          "test_cases": [
            {
              "comparison_type": "success",
              "expected_result": true
            }
          ],
          "points": 10
        },
        {
          "task_id": "task2",
          "template_name": "network_ping",
          "execution_device": "server1",
          "target_device": "server2",
          "parameters": {
            "target_ip": "{{ server2_ip }}",
            "ping_count": 3
          },
          "test_cases": [
            {
              "comparison_type": "success",
              "expected_result": true
            }
          ],
          "points": 15
        },
        {
          "task_id": "task3",
          "template_name": "service_check",
          "execution_device": "server2",
          "parameters": {
            "service_name": "nginx",
            "port": 80,
            "expected_status": "active"
          },
          "test_cases": [
            {
              "comparison_type": "equals",
              "expected_result": true
            }
          ],
          "points": 20
        },
        {
          "task_id": "task4",
          "template_name": "network_ping",
          "execution_device": "router1",
          "parameters": {
            "target_ip": "{{ server1_ip }}",
            "ping_count": 5
          },
          "test_cases": [
            {
              "comparison_type": "success",
              "expected_result": true
            }
          ],
          "points": 15
        },
        {
          "task_id": "task5",
          "template_name": "linux_ip_check",
          "execution_device": "server2",
          "parameters": {
            "interface_name": "eth1",
            "expected_ip": "10.0.1.20"
          },
          "test_cases": [
            {
              "comparison_type": "success",
              "expected_result": true
            }
          ],
          "points": 10
        }
      ]
    }
  },
  "devices": [
    {
      "id": "server1",
      "ip_address": "192.168.1.10",
      "ansible_connection": "ssh",
      "credentials": {
        "ansible_user": "ubuntu",
        "ansible_password": "ubuntu123"
      }
    },
    {
      "id": "server2",
      "ip_address": "192.168.1.20",
      "ansible_connection": "ssh",
      "credentials": {
        "ansible_user": "ubuntu",
        "ansible_password": "ubuntu123"
      }
    },
    {
      "id": "router1",
      "ip_address": "10.0.0.1",
      "ansible_connection": "ansible.netcommon.network_cli",
      "credentials": {
        "ansible_user": "admin",
        "ansible_password": "cisco123"
      },
      "platform": "cisco.ios.ios"
    }
  ],
  "ip_mappings": {
    "server1_ip": "192.168.1.10",
    "server2_ip": "192.168.1.20",
    "router1_mgmt_ip": "10.0.0.1",
    "network_subnet": "192.168.1.0/24"
  },
  "callback_url": "http://main-server:4000/api/v1/grading/callbacks"
