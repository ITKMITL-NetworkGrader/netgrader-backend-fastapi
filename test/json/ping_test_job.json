{
  "job_id": "ping_test_core_router_001",
  "instructor_id": "instructor_001",
  "lab_name": "Core Router Connectivity Test",
  "student_id": "student_001",
  "topology": {
    "devices": [
      {
        "hostname": "core_router",
        "ip_address": "192.168.1.1",
        "connection_type": "ansible.netcommon.network_cli",
        "platform": "cisco.ios.ios",
        "username": "admin",
        "password": "cisco"
      }
    ],
    "tests": [
      {
        "name": "Core Router Internet Connectivity",
        "template": "network_ping.j2",
        "target_device": ["core_router"],
        "vars": {
          "target_ip": "8.8.8.8",
          "ping_count": 5
        },
        "test_cases": [
          {
            "description": "success_rate",
            "expected_value": 80,
            "comparison_type": "greater_than",
            "points": 15,
            "required": true
          },
          {
            "description": "packets_received",
            "expected_value": 3,
            "comparison_type": "greater_than",
            "points": 8,
            "required": true
          },
          {
            "description": "avg_rtt",
            "expected_value": {
              "min": 0,
              "max": 100
            },
            "comparison_type": "range",
            "points": 5,
            "required": false
          },
          {
            "description": "status",
            "expected_value": "success",
            "comparison_type": "equals",
            "points": 2,
            "required": true
          }
        ],
        "points": 30
      }
    ]
  },
  "callback_url": "http://localhost:4000/api/grading/callbacks",
  "total_points": 30
}